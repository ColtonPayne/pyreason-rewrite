{
  "id": "fact-text-malformed",
  "purpose": "First malformed tranche of the fact-text DSL: each probe hands the Fact constructor one input class from docs/surface.md dsl:fact-text and records the outcome (exception type + message, or acceptance) — the parser's rejection behavior is the compared contract. bound-predicate-charset rides along because the pin's predicate regex accepts '-' and '.', so a hyphenated predicate is an accepted boundary shape, not a malformed one. No reasoning runs; the probes are pure constructions.",
  "runtime_class": "smoke",
  "provenance": "spine cases against docs/surface.md dsl:fact-text malformed classes; shapes from docs/analysis/surface/facts-and-graph.md",
  "surface_items": ["type:Fact", "dsl:fact-text"],
  "inputs": {"settings": {"verbose": false}},
  "probes": [
    {"id": "malformed-empty", "kind": "expect_raise", "construct": "fact",
     "args": {"text": ""}},
    {"id": "malformed-double-negation", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "~~sick(Alice)"}},
    {"id": "malformed-multi-colon", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "sick(Alice):[0,1]:[0,1]"}},
    {"id": "malformed-empty-predcomp", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "~"}},
    {"id": "malformed-no-parens", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "sickAlice"}},
    {"id": "malformed-paren-count", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "sick((Alice)"}},
    {"id": "malformed-paren-order", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "sick)Alice("}},
    {"id": "malformed-empty-component", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "sick()"}},
    {"id": "malformed-edge-arity", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "contact(Alice,Bob,Carol)"}},
    {"id": "malformed-empty-edge-component", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "contact(Alice,)"}},
    {"id": "malformed-predicate-leading-digit", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "1sick(Alice)"}},
    {"id": "malformed-predicate-badchar", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "si$ck(Alice)"}},
    {"id": "bound-predicate-charset", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "si-ck.v2(Alice)"}},
    {"id": "malformed-interval-nonnumeric", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "sick(Alice):[low,high]"}},
    {"id": "malformed-interval-out-of-range", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "sick(Alice):[0,2]"}},
    {"id": "malformed-interval-inverted", "kind": "expect_raise", "construct": "fact",
     "args": {"text": "sick(Alice):[1,0]"}}
  ],
  "comparison": {"probes": {}}
}
