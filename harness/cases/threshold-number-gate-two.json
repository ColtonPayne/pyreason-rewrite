{
  "id": "threshold-number-gate-two",
  "purpose": "List-form custom_thresholds through pr.Rule: [greater_equal number/total 1, greater_equal number/total 2] on trendy(x) <-1 Friends(x,y), popular(y) \u2014 the popular(y) clause has one qualifying grounding (B), 1 < 2, so the rule never fires anywhere (empty trendy trace/frames) while the default twin derives trendy(A). Pins accepted-threshold SEMANTICS (the board's named gap: rule-from-json banked threshold rejections; this banks what an accepted threshold does).",
  "runtime_class": "smoke",
  "provenance": "docs/surface.md type:Threshold happy-number-total + interacts-to_tuple (thresh coerced to float64 at rule_parser.py:160); screened live 2026-07-07 (screen_thresh2.py gate-two)",
  "surface_items": [
    "type:Threshold",
    "fn:add_rule",
    "fn:reason",
    "fn:load_graph",
    "fn:add_fact",
    "fn:get_rule_trace",
    "fn:filter_and_sort_nodes",
    "fn:get_time",
    "type:Rule",
    "type:Fact",
    "dsl:rule-text",
    "dsl:fact-text",
    "setting:atom_trace",
    "setting:verbose"
  ],
  "inputs": {
    "settings": {
      "verbose": false,
      "atom_trace": true
    },
    "graph": {
      "nodes": [
        "A",
        "B",
        "C"
      ],
      "edges": [
        [
          "A",
          "B",
          {
            "Friends": 1
          }
        ],
        [
          "A",
          "C",
          {
            "Friends": 1
          }
        ]
      ]
    },
    "rules": [
      {
        "text": "trendy(x) <-1 Friends(x,y), popular(y)",
        "name": "trendy_rule",
        "custom_thresholds": [
          {
            "quantifier": "greater_equal",
            "quantifier_type": [
              "number",
              "total"
            ],
            "thresh": 1
          },
          {
            "quantifier": "greater_equal",
            "quantifier_type": [
              "number",
              "total"
            ],
            "thresh": 2
          }
        ]
      }
    ],
    "facts": [
      {
        "text": "popular(B)",
        "name": "f_b",
        "start": 0,
        "end": 2
      }
    ],
    "reason": {
      "timesteps": 1
    }
  },
  "probes": [
    {
      "id": "trace-node",
      "kind": "rule_trace_node"
    },
    {
      "id": "nodes-trendy",
      "kind": "filter_sort_nodes",
      "labels": [
        "trendy"
      ]
    },
    {
      "id": "time",
      "kind": "get_time"
    }
  ],
  "comparison": {
    "probes": {}
  }
}
