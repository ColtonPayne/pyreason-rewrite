{
  "id": "conv-delta-bound",
  "purpose": "reason(timesteps=-1, convergence_bound_threshold=0.001) selects delta_bound: the run ends at the first timestep whose maximum bound change is <= 0.001. convergence_threshold=500 is set alongside because delta_bound dominates it entirely (interpretation.py:185-187) — were the interpretation-change count consulted, the run would stop at t=0.",
  "runtime_class": "standard",
  "provenance": "spine case against docs/surface.md fn:reason conv-delta-bound (threshold-precedence included); hello-world program",
  "surface_items": [
    "fn:load_graph", "fn:add_rule", "fn:add_fact", "fn:reason",
    "fn:filter_and_sort_nodes", "fn:get_rule_trace", "fn:get_time",
    "type:Rule", "type:Fact", "dsl:rule-text", "dsl:fact-text",
    "setting:atom_trace", "setting:verbose"
  ],
  "inputs": {
    "settings": {"verbose": false, "atom_trace": true},
    "graph": {
      "nodes": ["John", "Mary", "Justin", "Dog", "Cat"],
      "edges": [
        ["Justin", "Mary", {"Friends": 1}],
        ["John", "Mary", {"Friends": 1}],
        ["John", "Justin", {"Friends": 1}],
        ["Mary", "Cat", {"owns": 1}],
        ["Justin", "Cat", {"owns": 1}],
        ["Justin", "Dog", {"owns": 1}],
        ["John", "Dog", {"owns": 1}]
      ]
    },
    "rules": [
      {"text": "popular(x) <-1 popular(y), Friends(x,y), owns(y,z), owns(x,z)", "name": "popular_rule"}
    ],
    "facts": [
      {"text": "popular(Mary)", "name": "popular_fact", "start": 0, "end": 2}
    ],
    "reason": {"timesteps": -1, "convergence_threshold": 500, "convergence_bound_threshold": 0.001}
  },
  "probes": [
    {"id": "nodes-popular", "kind": "filter_sort_nodes", "labels": ["popular"]},
    {"id": "trace-node", "kind": "rule_trace_node"},
    {"id": "time", "kind": "get_time"}
  ],
  "comparison": {"probes": {}}
}
