{
  "id": "reason-again-no-program",
  "purpose": "reason(again=True) as the process's first reasoning call: the `not again or __program is None` short-circuit silently degrades it to a fresh run instead of asserting — the again-but-no-program class, proven by outputs matching a fresh run's shape (one-step form).",
  "runtime_class": "smoke",
  "provenance": "spine case against docs/surface.md fn:reason again-but-no-program (pyreason.py:1516 short-circuit)",
  "surface_items": [
    "fn:load_graph", "fn:add_rule", "fn:add_fact", "fn:reason",
    "fn:filter_and_sort_nodes", "fn:get_rule_trace", "fn:get_time",
    "type:Rule", "type:Fact", "dsl:rule-text", "dsl:fact-text",
    "setting:atom_trace", "setting:verbose"
  ],
  "inputs": {
    "settings": {"verbose": false, "atom_trace": true},
    "graph": {
      "nodes": ["John", "Mary", "Justin", "Dog", "Cat"],
      "edges": [
        ["Justin", "Mary", {"Friends": 1}],
        ["John", "Mary", {"Friends": 1}],
        ["John", "Justin", {"Friends": 1}],
        ["Mary", "Cat", {"owns": 1}],
        ["Justin", "Cat", {"owns": 1}],
        ["Justin", "Dog", {"owns": 1}],
        ["John", "Dog", {"owns": 1}]
      ]
    },
    "rules": [
      {"text": "popular(x) <-1 popular(y), Friends(x,y), owns(y,z), owns(x,z)", "name": "popular_rule"}
    ],
    "facts": [
      {"text": "popular(Mary)", "name": "popular_fact", "start": 0, "end": 2}
    ],
    "reason": {"timesteps": 2, "again": true}
  },
  "probes": [
    {"id": "time", "kind": "get_time"},
    {"id": "nodes-popular", "kind": "filter_sort_nodes", "labels": ["popular"]},
    {"id": "trace-node", "kind": "rule_trace_node"}
  ],
  "comparison": {"probes": {}}
}
