{
  "id": "fp-version-on",
  "purpose": "settings.fp_version=true routes reason() through interpretation_fp (the fixed-point engine, selected only when parallel_computing is off): hello-world inputs pin the fp engine's own node frames and traces — which differ from the optimized engine's on identical inputs (fp-counter values, event order, duplicated atom-trace groundings; same final bounds) — plus the knob's live value. First capture in a fresh env pays the fp path's one-time numba compile (~60s on this machine; ~7s warm).",
  "runtime_class": "standard",
  "provenance": "spine case against docs/surface.md setting:fp_version nondefault-true-fp; hello-world inputs, knob flipped",
  "surface_items": [
    "fn:load_graph", "fn:add_rule", "fn:add_fact", "fn:reason",
    "fn:filter_and_sort_nodes", "fn:get_rule_trace", "fn:get_time",
    "type:Rule", "type:Fact", "dsl:rule-text", "dsl:fact-text",
    "setting:fp_version", "setting:atom_trace", "setting:verbose"
  ],
  "inputs": {
    "settings": {"verbose": false, "atom_trace": true, "fp_version": true},
    "graph": {
      "nodes": ["John", "Mary", "Justin", "Dog", "Cat"],
      "edges": [
        ["Justin", "Mary", {"Friends": 1}],
        ["John", "Mary", {"Friends": 1}],
        ["John", "Justin", {"Friends": 1}],
        ["Mary", "Cat", {"owns": 1}],
        ["Justin", "Cat", {"owns": 1}],
        ["Justin", "Dog", {"owns": 1}],
        ["John", "Dog", {"owns": 1}]
      ]
    },
    "rules": [
      {"text": "popular(x) <-1 popular(y), Friends(x,y), owns(y,z), owns(x,z)", "name": "popular_rule"}
    ],
    "facts": [
      {"text": "popular(Mary)", "name": "popular_fact", "start": 0, "end": 2}
    ],
    "reason": {"timesteps": 2}
  },
  "probes": [
    {"id": "nodes-popular", "kind": "filter_sort_nodes", "labels": ["popular"]},
    {"id": "trace-node", "kind": "rule_trace_node"},
    {"id": "trace-edge", "kind": "rule_trace_edge"},
    {"id": "time", "kind": "get_time"},
    {"id": "fp-knob", "kind": "get_setting", "knob": "fp_version"}
  ],
  "comparison": {"probes": {}}
}
