{
  "id": "rule-text-malformed",
  "purpose": "First malformed tranche of the rule-text DSL: each probe hands the Rule constructor one malformed input class from docs/surface.md dsl:rule-text and records the outcome (exception type + message, or acceptance) — the parser's rejection behavior is the compared contract. No reasoning runs; the probes are pure constructions.",
  "runtime_class": "smoke",
  "provenance": "spine cases against docs/surface.md dsl:rule-text malformed classes; shapes from docs/analysis/surface/rules.md",
  "surface_items": ["type:Rule", "dsl:rule-text"],
  "inputs": {"settings": {"verbose": false}},
  "probes": [
    {"id": "malformed-non-string", "kind": "expect_raise", "construct": "rule",
     "args": {"text": 123}},
    {"id": "malformed-empty", "kind": "expect_raise", "construct": "rule",
     "args": {"text": ""}},
    {"id": "malformed-arrow-count-zero", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "popular(x)"}},
    {"id": "malformed-arrow-count-two", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "popular(x) <- popular(y) <- popular(z)"}},
    {"id": "malformed-empty-head", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "<-1 popular(y)"}},
    {"id": "malformed-trailing-comma", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "popular(x) <-1 popular(y),"}},
    {"id": "malformed-clause-no-parens", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "popular(x) <-1 popular"}},
    {"id": "malformed-bound-arity", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "popular(x):[0.5] <-1 popular(y)"}},
    {"id": "malformed-bound-nonnumeric", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "popular(x):[low,high] <-1 popular(y)"}},
    {"id": "malformed-bound-out-of-range", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "popular(x):[0,2] <-1 popular(y)"}},
    {"id": "malformed-bound-inverted", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "popular(x):[1,0] <-1 popular(y)"}},
    {"id": "malformed-double-negation-body", "kind": "expect_raise", "construct": "rule",
     "args": {"text": "popular(x) <-1 ~~popular(y)"}}
  ],
  "comparison": {"probes": {}}
}
