{
  "id": "update-mode-override",
  "purpose": "settings.update_mode='override' replaces bounds instead of intersecting (set_lower_upper vs world.update at the pin): the second same-atom fact wins wholesale (wide(A) [0.2,1] then [0,0.8] -> [0,0.8]), whose lower bound fails the rule's [0.1,1] clause bound so derived(B) never appears — same inputs as update-mode-default, observably different reasoning.",
  "runtime_class": "smoke",
  "provenance": "spine case against docs/surface.md setting:update_mode nondefault-override",
  "surface_items": [
    "fn:load_graph", "fn:add_rule", "fn:add_fact", "fn:reason",
    "fn:filter_and_sort_nodes", "fn:get_rule_trace", "fn:get_time",
    "type:Rule", "type:Fact", "dsl:rule-text", "dsl:fact-text",
    "setting:update_mode", "setting:atom_trace", "setting:verbose"
  ],
  "inputs": {
    "settings": {"verbose": false, "atom_trace": true, "update_mode": "override"},
    "graph": {
      "nodes": ["A", "B"],
      "edges": [
        ["A", "B", {"rel": 1}]
      ]
    },
    "rules": [
      {"text": "derived(y) <-1 wide(x):[0.1,1.0], rel(x,y)", "name": "derived_rule"}
    ],
    "facts": [
      {"text": "wide(A):[0.2,1.0]", "name": "wide_fact_1", "start": 0, "end": 0},
      {"text": "wide(A):[0.0,0.8]", "name": "wide_fact_2", "start": 0, "end": 0}
    ],
    "reason": {"timesteps": 2}
  },
  "probes": [
    {"id": "nodes-wide-derived", "kind": "filter_sort_nodes", "labels": ["wide", "derived"]},
    {"id": "trace-node", "kind": "rule_trace_node"},
    {"id": "trace-edge", "kind": "rule_trace_edge"},
    {"id": "time", "kind": "get_time"},
    {"id": "mode-knob", "kind": "get_setting", "knob": "update_mode"}
  ],
  "comparison": {"probes": {}}
}
