{
  "id": "threshold-dict-gate",
  "purpose": "Dict-form custom_thresholds through pr.Rule ({clause-index 1: greater_equal number/total 2}, clause 0 defaulted to greater_equal number/total 1 by the parser, rule_parser.py:169-173): behaviorally identical to the full list form on the same program \u2014 no trendy row derives \u2014 pinning that the dict form's defaulting reaches the same consumed thresholds. Differential against threshold-number-gate-default's derivation.",
  "runtime_class": "smoke",
  "provenance": "docs/surface.md type:Threshold (dict-form consumption); rule_parser.py:161-173 at the pin; screened live 2026-07-07 (screen_thresh2.py gate-dict)",
  "surface_items": [
    "type:Threshold",
    "fn:add_rule",
    "fn:reason",
    "fn:load_graph",
