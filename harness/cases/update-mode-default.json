{
  "id": "update-mode-default",
  "purpose": "settings.update_mode left at its default 'intersection': two same-atom facts intersect (wide(A) [0.2,1] then [0,0.8] -> [0.2,0.8]), which satisfies the rule's [0.1,1] clause bound so derived(B) appears at t=1 — the baseline twin whose probe digests update-mode-junk-string must equal and update-mode-override must not.",
  "runtime_class": "smoke",
  "provenance": "spine case against docs/surface.md setting:update_mode default-intersection",
  "surface_items": [
    "fn:load_graph", "fn:add_rule", "fn:add_fact", "fn:reason",
    "fn:filter_and_sort_nodes", "fn:get_rule_trace", "fn:get_time",
    "type:Rule", "type:Fact", "dsl:rule-text", "dsl:fact-text",
    "setting:update_mode", "setting:atom_trace", "setting:verbose"
  ],
  "inputs": {
    "settings": {"verbose": false, "atom_trace": true},
    "graph": {
      "nodes": ["A", "B"],
      "edges": [
        ["A", "B", {"rel": 1}]
      ]
    },
    "rules": [
      {"text": "derived(y) <-1 wide(x):[0.1,1.0], rel(x,y)", "name": "derived_rule"}
    ],
    "facts": [
      {"text": "wide(A):[0.2,1.0]", "name": "wide_fact_1", "start": 0, "end": 0},
      {"text": "wide(A):[0.0,0.8]", "name": "wide_fact_2", "start": 0, "end": 0}
    ],
    "reason": {"timesteps": 2}
  },
  "probes": [
    {"id": "nodes-wide-derived", "kind": "filter_sort_nodes", "labels": ["wide", "derived"]},
    {"id": "trace-node", "kind": "rule_trace_node"},
    {"id": "trace-edge", "kind": "rule_trace_edge"},
    {"id": "time", "kind": "get_time"},
    {"id": "mode-knob", "kind": "get_setting", "knob": "update_mode"}
  ],
  "comparison": {"probes": {}}
}
