{
  "id": "conv-perfect",
  "purpose": "reason(timesteps=-1) with both convergence thresholds defaulted selects perfect_convergence: the loop ends only past max_facts_time and max_rules_time. The friends graph is acyclic along the diffusion direction, so the rederivation chain is finite and the run terminates.",
  "runtime_class": "standard",
  "provenance": "spine case against docs/surface.md fn:reason conv-perfect + timesteps-neg1-run-to-convergence; hello-world program",
  "surface_items": [
    "fn:load_graph", "fn:add_rule", "fn:add_fact", "fn:reason",
    "fn:filter_and_sort_nodes", "fn:get_rule_trace", "fn:get_time",
    "type:Rule", "type:Fact", "dsl:rule-text", "dsl:fact-text",
    "setting:atom_trace", "setting:verbose"
  ],
  "inputs": {
    "settings": {"verbose": false, "atom_trace": true},
    "graph": {
      "nodes": ["John", "Mary", "Justin", "Dog", "Cat"],
      "edges": [
        ["Justin", "Mary", {"Friends": 1}],
        ["John", "Mary", {"Friends": 1}],
        ["John", "Justin", {"Friends": 1}],
        ["Mary", "Cat", {"owns": 1}],
        ["Justin", "Cat", {"owns": 1}],
        ["Justin", "Dog", {"owns": 1}],
        ["John", "Dog", {"owns": 1}]
      ]
    },
    "rules": [
      {"text": "popular(x) <-1 popular(y), Friends(x,y), owns(y,z), owns(x,z)", "name": "popular_rule"}
    ],
    "facts": [
      {"text": "popular(Mary)", "name": "popular_fact", "start": 0, "end": 2}
    ],
    "reason": {"timesteps": -1}
  },
  "probes": [
    {"id": "nodes-popular", "kind": "filter_sort_nodes", "labels": ["popular"]},
    {"id": "trace-node", "kind": "rule_trace_node"},
    {"id": "time", "kind": "get_time"}
  ],
  "comparison": {"probes": {}}
}
