{
  "id": "persistent-off",
  "purpose": "settings.persistent left at its default False: a one-timestep fact window [0,0] plus timesteps=2 shows every non-static bound reset to [0,1] at each new timestep while the static special(Dog) fact escapes the reset — the default-false-nonpersistent and interaction-static classes in one observable contrast with persistent-on.",
  "runtime_class": "smoke",
  "provenance": "spine case against docs/surface.md setting:persistent; hello-world program with a narrowed fact window + a static fact",
  "surface_items": [
    "fn:load_graph", "fn:add_rule", "fn:add_fact", "fn:reason",
    "fn:filter_and_sort_nodes", "fn:get_rule_trace", "fn:get_time",
    "type:Rule", "type:Fact", "dsl:rule-text", "dsl:fact-text",
    "setting:persistent", "setting:atom_trace", "setting:verbose"
  ],
  "inputs": {
    "settings": {"verbose": false, "atom_trace": true, "persistent": false},
    "graph": {
      "nodes": ["John", "Mary", "Justin", "Dog", "Cat"],
      "edges": [
        ["Justin", "Mary", {"Friends": 1}],
        ["John", "Mary", {"Friends": 1}],
        ["John", "Justin", {"Friends": 1}],
        ["Mary", "Cat", {"owns": 1}],
        ["Justin", "Cat", {"owns": 1}],
        ["Justin", "Dog", {"owns": 1}],
        ["John", "Dog", {"owns": 1}]
      ]
    },
    "rules": [
      {"text": "popular(x) <-1 popular(y), Friends(x,y), owns(y,z), owns(x,z)", "name": "popular_rule"}
    ],
    "facts": [
      {"text": "popular(Mary)", "name": "popular_fact", "start": 0, "end": 0},
      {"text": "special(Dog)", "name": "special_fact", "start": 0, "end": 0, "static": true}
    ],
    "reason": {"timesteps": 2}
  },
  "probes": [
    {"id": "nodes-popular-special", "kind": "filter_sort_nodes", "labels": ["popular", "special"]},
    {"id": "interp-dict", "kind": "interpretation_dict"},
    {"id": "trace-node", "kind": "rule_trace_node"},
    {"id": "time", "kind": "get_time"}
  ],
  "comparison": {"probes": {}}
}
