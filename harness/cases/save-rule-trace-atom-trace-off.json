{
  "id": "save-rule-trace-atom-trace-off",
  "purpose": "save_rule_trace with atom_trace off over the same hello-world program: the CSVs keep the fixed 10-column header (no Clause-i columns), Old Bound stays the '-' placeholder, and Occurred Due To carries the rule/fact name from the trace tuple instead of the atom-trace grounding — the atom-trace-columns class's off arm.",
  "runtime_class": "smoke",
  "provenance": "twin of save-rule-trace-basic against docs/surface.md fn:save_rule_trace atom-trace-columns (off arm); output.py:24-47 at the pin",
  "surface_items": [
    "fn:load_graph", "fn:add_rule", "fn:add_fact", "fn:reason",
    "fn:save_rule_trace",
    "type:Rule", "type:Fact", "dsl:rule-text", "dsl:fact-text",
    "setting:atom_trace", "setting:verbose"
  ],
  "inputs": {
    "settings": {"verbose": false, "atom_trace": false},
    "graph": {
      "nodes": ["John", "Mary", "Justin", "Dog", "Cat"],
      "edges": [
        ["Justin", "Mary", {"Friends": 1}],
        ["John", "Mary", {"Friends": 1}],
        ["John", "Justin", {"Friends": 1}],
        ["Mary", "Cat", {"owns": 1}],
        ["Justin", "Cat", {"owns": 1}],
        ["Justin", "Dog", {"owns": 1}],
        ["John", "Dog", {"owns": 1}]
      ]
    },
    "rules": [
      {"text": "popular(x) <-1 popular(y), Friends(x,y), owns(y,z), owns(x,z)", "name": "popular_rule"}
    ],
    "facts": [
      {"text": "popular(Mary)", "name": "popular_fact", "start": 0, "end": 2}
    ],
    "reason": {"timesteps": 2}
  },
  "probes": [
    {"id": "srt-default", "kind": "save_rule_trace"}
  ],
  "comparison": {"probes": {}}
}
